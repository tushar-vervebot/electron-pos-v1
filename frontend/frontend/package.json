  },
  "dependencies": {
    "axios": "^1.6.8",
    "better-sqlite3": "^12.8.0",
    "react-hot-toast": "^2.4.1",
    "ws": "^8.20.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.neerajpandey.pos",
