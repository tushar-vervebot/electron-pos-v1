{
  "name": "pos-frontend",
  "version": "1.0.0",
  "description": "POS System - Electron Frontend",
  "main": "out/main/index.js",
  "author": "Neeraj Pandey",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
