{
    "name": "pos-system",
    "version": "1.0.15",
    "description": "Point of Sale System for Windows",
    "main": "electron/main/main.js",
    "scripts": {
        "start": "electron-forge start",
        "dev": "node_modules\\electron\\dist\\electron.exe electron\\main\\main.js",
        "package": "electron-forge package",
        "make": "electron-forge make",
        "make:msi": "electron-forge package && node build-msi.js",
        "dist:win": "electron-builder --win nsis --publish never",
        "serve:updates": "node serve-updates.js"
    },
    "keywords": [],
    "author": {
        "name": "Your Company Name",
        "email": "support@yourcompany.com"
    },
    "license": "UNLICENSED",
    "type": "commonjs",
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-wix": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-fuses": "^7.11.1",
        "@electron/fuses": "^1.8.0",
        "@yao-pkg/pkg": "^6.14.2",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "electron-log": "^5.4.3",
        "electron-updater": "^6.8.3",
        "serialport": "^12.0.0",
        "ws": "^8.20.0"
    },
    "build": {
        "appId": "com.yourcompany.possystem",
        "productName": "POS System",
        "afterPack": "build/afterPack.js",
        "asar": true,
        "files": [
            "src/**/*",
            "assets/**/*",
            "package.json",
            "!**/*.map",
            "!tools{,/**}",
            "!out{,/**}"
        ],
        "extraResources": [
            {
                "from": "src/services/pos-health",
                "to": "services/pos-health"
            }
        ],
        "win": {
            "icon": "assets/icon.ico",
            "signAndEditExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "include": "build/installer.nsh",
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "POS System",
            "artifactName": "POS-System-Setup-${version}.${ext}"
        },
        "publish": [
            {
                "provider": "generic",
                "url": "http://192.168.68.105:8080"
            }
        ]
    }
}
